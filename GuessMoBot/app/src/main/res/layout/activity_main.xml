<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1e">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🤖 GuessMo Bot"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#e91e8c"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto-answers Find the Emoji on guessmopay.pro"
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- START/STOP Button -->
        <Button
            android:id="@+id/start_stop_button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="▶ START BOT"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#43a047"
            android:textColor="#ffffff"
            android:layout_marginBottom="20dp"/>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1e1e3f"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BOT STATUS"
                android:textColor="#888888"
                android:textSize="10sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Checking..."
                android:textSize="15sp"
                android:textColor="#ffffff"/>

            <TextView
                android:id="@+id/answer_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last answer: —"
                android:textSize="12sp"
                android:textColor="#aaaaaa"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- API Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STEP 1 — Gemini or Claude API Key"
            android:textColor="#e91e8c"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/api_key_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Paste your Gemini or Claude API key"
            android:inputType="textPassword"
            android:textColor="#ffffff"
            android:textColorHint="#555555"
            android:background="#1e1e3f"
            android:padding="14dp"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/save_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save API Key"
            android:backgroundTint="#e91e8c"
            android:textColor="#ffffff"
            android:layout_marginBottom="24dp"/>

        <!-- Accessibility -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STEP 2 — Enable Accessibility Service"
            android:textColor="#e91e8c"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/accessibility_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Open Accessibility Settings"
            android:backgroundTint="#6c3f8f"
            android:textColor="#ffffff"
            android:layout_marginBottom="24dp"/>

        <!-- How to use -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STEP 3 — How to use"
            android:textColor="#e91e8c"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Tap START BOT above\n2. Switch to Brave browser\n3. Open guessmopay.pro → Find the Emoji\n4. Bot auto-answers every 5 seconds!"
            android:textColor="#888888"
            android:textSize="13sp"
            android:lineSpacingExtra="6dp"/>

    </LinearLayout>
</ScrollView>
